      <section className="bg-wdd-yellow grid grid-cols-2 min-h-64">
        <div className="bg-wdd-mud/60 flex items-center justify-center relative">
          <span className="text-xs font-light text-white/25 uppercase tracking-wider text-center px-8 relative z-10">Photo chantier geothermie ouverte forage nappe</span>
          <div className="absolute inset-0 bg-wdd-yellow/10" />
        </div>
        <div className="px-14 py-14 flex flex-col justify-center">
          <div className="text-xs font-light tracking-widest text-wdd-black/40 uppercase mb-3">Geothermie ouverte</div>
          <h2 className="text-3xl font-bold text-wdd-black mb-6 leading-tight">Envie de decarboner<br />votre chaleur ?</h2>
          <div className="flex items-center gap-4">
            <Link href={getLocalizedPath(loc, 'devis')} className="bg-wdd-black text-wdd-yellow px-7 py-3.5 text-sm font-bold border-2 border-wdd-black hover:bg-transparent hover:text-wdd-black transition-colors">
              Oui, je diminue mon empreinte
            </Link>
            <Link href={getLocalizedPath(loc, 'geo_fermee')} className="text-sm font-light text-wdd-black/55 border-b border-wdd-black/25 hover:text-wdd-black transition-colors pb-0.5">
              Voir la geothermie fermee
            </Link>
          </div>
        </div>
      </section>

    </div>
  )
}

// ─── CATCH ALL ────────────────────────────────────────────────────────────────
export default async function LocalizedCatchAllPage({ params }: PageProps) {
  const { locale, slug } = await params
  const slugPath = slug.join('/')
  const routeKey = findRouteKeyBySlug(locale, slugPath)

  if (!routeKey || routeKey === 'home') notFound()

  switch (routeKey) {
    case 'geo_fermee':
      return <GeoFermeePage locale={locale} />
    case 'devis':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Page devis — a venir</h1></div>
    case 'geo_ouverte':
      return <GeoOuverte locale={locale} />
    case 'references':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Page references — a venir</h1></div>
    case 'calculateur':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Page calculateur — a venir</h1></div>
    case 'pac_fonctionnement':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">PAC fonctionnement — a venir</h1></div>
    case 'pac_chauffage':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">PAC chauffage — a venir</h1></div>
    case 'pac_climatisation':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">PAC climatisation — a venir</h1></div>
    case 'pac_avantages':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">PAC avantages — a venir</h1></div>
    case 'geo_fonctionnement':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Geo fonctionnement — a venir</h1></div>
    case 'particuliers_etapes':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Etapes chantier — a venir</h1></div>
    case 'particuliers_installateurs':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Installateurs — a venir</h1></div>
    case 'pro_chauffagistes':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Chauffagistes — a venir</h1></div>
    case 'pro_architectes':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Architectes — a venir</h1></div>
    case 'pro_entrepreneurs':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Entrepreneurs — a venir</h1></div>
    case 'pro_soumission':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Soumission — a venir</h1></div>
    case 'blog':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Blog — a venir</h1></div>
    case 'mentions_legales':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Mentions legales — a venir</h1></div>
    case 'politique_confidentialite':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Politique de confidentialite — a venir</h1></div>
    case 'cookies':
      return <div className="pt-32 px-16 min-h-screen bg-wdd-clay"><h1 className="text-4xl font-bold">Cookies — a venir</h1></div>
    default:
      notFound()
  }
}
